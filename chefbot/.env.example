# ChefBot — variables de entorno
# Copia este archivo a `.env.local` para desarrollo o configura estas mismas
# claves en Netlify (Site settings → Environment variables).

# ── Supabase (cliente, expuestas al navegador) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Groq (servidor, NUNCA expuesta al navegador) ────────────────────────────
GROQ_API_KEY=gsk_...

# Opcional: cambia el modelo por defecto (default: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.3-70b-versatile